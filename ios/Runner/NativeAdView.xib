<?xml version="1.0" encoding="UTF-8"?>
<document
    type="com.apple.InterfaceBuilder3.CocoaTouch.XIB"
    version="3.0"
    toolsVersion="18122"
    targetRuntime="iOS.CocoaTouch"
    propertyAccessControl="none"
    useAutolayout="YES"
    useTraitCollections="YES"
    colorMatched="YES">

    <device id="retina6_1" orientation="portrait" appearance="light"/>

    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="18093"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>

    <objects>

        <view
            contentMode="scaleToFill"
            id="native-ad-view"
            customClass="GADNativeAdView">

            <rect key="frame" x="0.0" y="0.0" width="375" height="120"/>

            <subviews>

                <!-- Icon -->
                <imageView
                    contentMode="scaleAspectFit"
                    translatesAutoresizingMaskIntoConstraints="NO"
                    id="icon-view">

                    <rect key="frame" x="12" y="20" width="60" height="60"/>
                </imageView>

                <!-- Headline -->
                <label
                    opaque="NO"
                    userInteractionEnabled="NO"
                    contentMode="left"
                    text="広告タイトル"
                    lineBreakMode="tailTruncation"
                    numberOfLines="2"
                    translatesAutoresizingMaskIntoConstraints="NO"
                    id="headline-view">

                    <rect key="frame" x="84" y="16" width="220" height="40"/>

                    <fontDescription
                        key="fontDescription"
                        type="boldSystem"
                        pointSize="16"/>
                </label>

                <!-- Body -->
                <label
                    opaque="NO"
                    userInteractionEnabled="NO"
                    contentMode="left"
                    text="広告本文"
                    lineBreakMode="tailTruncation"
                    numberOfLines="2"
                    translatesAutoresizingMaskIntoConstraints="NO"
                    id="body-view">

                    <rect key="frame" x="84" y="58" width="220" height="34"/>

                    <fontDescription
                        key="fontDescription"
                        type="system"
                        pointSize="13"/>
                </label>

                <!-- CTA -->
                <button
                    opaque="NO"
                    contentMode="scaleToFill"
                    translatesAutoresizingMaskIntoConstraints="NO"
                    id="cta-view">

                    <rect key="frame" x="260" y="82" width="90" height="28"/>

                    <state key="normal" title="詳細"/>
                </button>

            </subviews>

            <color
                key="backgroundColor"
                systemColor="systemBackgroundColor"/>

            <constraints>

                <constraint
                    firstItem="icon-view"
                    firstAttribute="leading"
                    secondItem="native-ad-view"
                    secondAttribute="leading"
                    constant="12"
                    id="icon-leading"/>

                <constraint
                    firstItem="icon-view"
                    firstAttribute="top"
                    secondItem="native-ad-view"
                    secondAttribute="top"
                    constant="20"
                    id="icon-top"/>

                <constraint
                    firstItem="headline-view"
                    firstAttribute="leading"
                    secondItem="icon-view"
                    secondAttribute="trailing"
                    constant="12"
                    id="headline-leading"/>

                <constraint
                    firstItem="headline-view"
                    firstAttribute="top"
                    secondItem="native-ad-view"
                    secondAttribute="top"
                    constant="16"
                    id="headline-top"/>

                <constraint
                    firstItem="body-view"
                    firstAttribute="leading"
                    secondItem="headline-view"
                    secondAttribute="leading"
                    id="body-leading"/>

                <constraint
                    firstItem="body-view"
                    firstAttribute="top"
                    secondItem="headline-view"
                    secondAttribute="bottom"
                    constant="6"
                    id="body-top"/>

                <constraint
                    firstItem="cta-view"
                    firstAttribute="trailing"
                    secondItem="native-ad-view"
                    secondAttribute="trailing"
                    constant="-12"
                    id="cta-trailing"/>

                <constraint
                    firstItem="cta-view"
                    firstAttribute="bottom"
                    secondItem="native-ad-view"
                    secondAttribute="bottom"
                    constant="-12"
                    id="cta-bottom"/>

            </constraints>

            <connections>

                <outlet property="headlineView" destination="headline-view" id="headline-outlet"/>
                <outlet property="bodyView" destination="body-view" id="body-outlet"/>
                <outlet property="iconView" destination="icon-view" id="icon-outlet"/>
                <outlet property="callToActionView" destination="cta-view" id="cta-outlet"/>

            </connections>

        </view>

    </objects>
</document>
